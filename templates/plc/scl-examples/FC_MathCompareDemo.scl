// 通用数学、比较、限幅和质量位示例（原 fc_math_compare_demo.json，改走外部 SCL）。
FUNCTION "FC_MathCompareDemo" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT
      Setpoint : Real;
      Actual : Real;
      Deadband : Real;
      OutMin : Real;
      OutMax : Real;
   END_VAR

   VAR_OUTPUT
      ErrorValue : Real;
      AbsError : Real;
      OutputValue : Real;
      InTolerance : Bool;
   END_VAR

BEGIN
   ErrorValue := Setpoint - Actual;
   AbsError := ABS(ErrorValue);
   OutputValue := LIMIT(MN := OutMin, IN := ErrorValue, MX := OutMax);
   InTolerance := AbsError <= Deadband;
END_FUNCTION
